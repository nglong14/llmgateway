      "targets": [
        {
          "expr": "gateway_http_in_flight_requests",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          },
          "min": 0,
          "max": 100
        },
        "overrides": []
      }
    },
    {
